source "https://rubygems.org"

# Plain Jekyll (not the github-pages gem). GitHub Pages' "Deploy from a
# branch" builder ignores this file and uses its own pinned Jekyll
# version, so this is mainly for local preview - but it also means this
# same Gemfile works unmodified if you ever build on Netlify or
# Cloudflare Pages instead.
gem "jekyll", "~> 4.3"

# Needed for `jekyll serve` locally on Ruby 3+ (removed from stdlib)
gem "webrick", "~> 1.8"
